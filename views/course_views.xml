<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_center_course" model="ir.actions.act_window">
            <field name="name">Course Templates</field>
            <field name="res_model">center.course</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_center_course_list" model="ir.ui.view">
            <field name="name">center.course.list</field>
            <field name="model">center.course</field>
            <field name="arch" type="xml">
                <list string="Course Templates">
                    <field name="name"/>
                    <field name="total_sessions"/>
                    <field name="total_classes" groups="base.group_erp_manager"/>
                </list>
            </field>
        </record>

        <record id="view_course_register_wizard_form" model="ir.ui.view">
            <field name="name">center.course.register.wizard.form</field>
            <field name="model">center.course.register.wizard</field>
            <field name="arch" type="xml">
                <form string="Register for this course">
                    <field name="is_student_user" invisible="1"/>
                    <group>
                        <field name="course_id"/>
                        <field name="student_id" readonly="is_student_user" options="{'no_create': True}"/>
                    </group>
                    <footer>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_center_course_form" model="ir.ui.view">
            <field name="name">center.course.form</field>
            <field name="model">center.course</field>
            <field name="arch" type="xml">
                <form string="Course Template">
                    <header>
                        <button name="action_open_register_wizard" string="Register for this Course" type="object" class="oe_highlight"/>
                    </header>

                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" icon="fa-users" style="pointer-events: none;">
                                <field string="Waiting" name="registered_count" widget="statinfo"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Course Name..."/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="total_sessions"/>
                                <field name="price_per_session"/>
                            </group>
                            <group>
                                <field name="total_classes" groups="base.group_erp_manager"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Classes" name="classes" groups="base.group_erp_manager">
                                <field name="class_ids"/>
                            </page>

                            <page string="Registered Student List" name="waiting_list" groups="base.group_erp_manager">
                                <field name="registered_student_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="email"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Description" name="description">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>