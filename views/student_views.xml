<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_assignment_list_student" model="ir.ui.view">
            <field name="name">assignment.list.student</field>
            <field name="model">center.assignment</field>
            <field name="arch" type="xml">
                <list decoration-success="state_for_student == 'submitted'"
                    decoration-warning="state_for_student == 'pending'"
                    decoration-danger="state_for_student == 'overdue'"
                    decoration-bf="state_for_student == 'graded'">
                    <field name="name"/>
                    <field name="class_id"/>
                    <field name="due_date"/>
                </list>
            </field>
        </record>

        <record id="action_my_profile_student" model="ir.actions.server">
            <field name="name">Open Student Profile</field>
            <field name="model_id" ref="model_center_student"/>
            <field name="state">code</field>
            <field name="code">
student = env['center.student'].search([('user_id', '=', env.uid)], limit=1)
if student:
    action = {
        'type': 'ir.actions.act_window',
        'name': 'My Profile',
        'res_model': 'center.student',
        'view_mode': 'form',
        'res_id': student.id,
        'target': 'current',
        }
            </field>
        </record>

    </data>
</odoo>