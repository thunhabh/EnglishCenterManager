<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_center_student" model="ir.actions.act_window">
            <field name="name">Student Profiles</field>
            <field name="res_model">center.student</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_assignment_list_student" model="ir.ui.view">
            <field name="name">assignment.list.student</field>
            <field name="model">center.assignment</field>
            <field name="arch" type="xml">
                <list decoration-success="state_for_student == 'submitted'"
                    decoration-warning="state_for_student == 'pending'"
                    decoration-danger="state_for_student == 'overdue'"
                    decoration-bf="state_for_student == 'graded'">
                    <field name="name"/>
                    <field name="class_id"/>
                    <field name="due_date"/>
                </list>
            </field>
        </record>

        <record id="action_my_profile_student" model="ir.actions.server">
            <field name="name">Open Student Profile</field>
            <field name="model_id" ref="english_center.model_center_student"/>
            <field name="state">code</field>
            <field name="code">
                action = model.action_open_my_profile()
            </field>
        </record>

        <record id="view_center_student_list" model="ir.ui.view">
            <field name="name">center.student.list</field>
            <field name="model">center.student</field>
            <field name="arch" type="xml">
                <list string="Student Profiles" editable="bottom">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="parent_name"/>
                    <field name="parent_phone"/>
                    <field name="credit"/>
                    <field name="debt"/>
                </list>
            </field>
        </record>

        <record id="view_center_student_form" model="ir.ui.view">
            <field name="name">center.student.form</field>
            <field name="model">center.student</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_student_schedule" type="object" class="oe_stat_button" icon="fa-calendar">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Study Schedule</span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title"><h1><field name="name"/></h1></div>
                        <group>
                            <group string="Account Information">
                                <field name="email"/>
                                <field name="user_id" readonly="1"/>
                            </group>
                            <group string="Parent">
                                <field name="parent_name"/>
                                <field name="parent_phone"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>