<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_center_student" model="ir.actions.act_window">
            <field name="name">Student Profiles</field>
            <field name="res_model">center.student</field>
            <field name="view_mode">list,form</field>
        </record>


        <record id="action_my_profile_student" model="ir.actions.server">
            <field name="name">Open Student Profile</field>
            <field name="model_id" ref="english_center.model_center_student"/>
            <field name="state">code</field>
            <field name="code">
                action = model.action_open_my_profile()
            </field>
        </record>

        <record id="view_center_student_list" model="ir.ui.view">
            <field name="name">center.student.list</field>
            <field name="model">center.student</field>
            <field name="arch" type="xml">
                <list string="Student Profiles">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="parent_name"/>
                    <field name="parent_phone"/>
                    <field name="billing"/>
                </list>
            </field>
        </record>

        <record id="view_center_student_form" model="ir.ui.view">
            <field name="name">center.student.form</field>
            <field name="model">center.student</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_student_schedule" type="object" class="oe_stat_button" icon="fa-calendar">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Study Schedule</span>
                                </div>
                            </button>
                            <button name="action_student_my_bills_history" type="object" class="oe_stat_button" icon="oi-archive">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Bills</span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title"><h1><field name="name"/></h1></div>
                        <group>
                            <group string="Account Information">
                                <field name="email"/>
                                <field name="user_id" readonly="1"/>
                                <field name="billing"/>
                            </group>
                            <group string="Parent">
                                <field name="parent_name"/>
                                <field name="parent_phone"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Classes" name="classes">
                                <field name="class_ids" readonly="1">
                                    <list string="Enrolled Classes">
                                        <field name="name" string="Class Code"/>
                                        <field name="course_id"/>
                                        <field name="teacher_id"/>
                                        <field name="start_date"/>
                                        <field name="state" widget="badge" decoration-info="state == 'recruiting'" decoration-success="state == 'active'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Registered Courses" name="courses">
                                <field name="registered_course_ids">
                                    <list string="Registered Courses">
                                        <field name="name" string="Course"/>
                                        <field name="total_sessions"/>
                                        <field name="price_per_session"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>