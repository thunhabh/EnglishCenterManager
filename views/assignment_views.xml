<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_center_assignment" model="ir.actions.act_window">
            <field name="name">Assignments</field>
            <field name="res_model">center.assignment</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_assignment_list_student" model="ir.ui.view">
            <field name="name">assignment.list.student</field>
            <field name="model">center.assignment</field>
            <field name="arch" type="xml">
                <list decoration-success="state_for_student == 'submitted'"
                    decoration-warning="state_for_student == 'pending'"
                    decoration-danger="state_for_student == 'overdue'"
                    decoration-bf="state_for_student == 'graded'">
                    <field name="name"/>
                    <field name="class_id"/>
                    <field name="due_date"/>
                </list>
            </field>
        </record>

        <record id="view_assignment_list_teacher" model="ir.ui.view">
            <field name="name">assignment.list.teacher</field>
            <field name="model">center.assignment</field>
            <field name="arch" type="xml">
                <list decoration-success="state_for_teacher in ('all_submitted', 'finished')"
                      decoration-warning="state_for_teacher == 'partial'"
                      decoration-info="state_for_teacher == 'overdue'"
                      decoration-bf="state_for_teacher == 'finished'">
                        <field name="class_id"/>
                        <field name="state_for_teacher"/>
                </list>
            </field>
        </record>

        <record id="view_center_assignment_form" model="ir.ui.view">
            <field name="name">center.assignment.form</field>
            <field name="model">center.assignment</field>
            <field name="arch" type="xml">
                <form string="Assignment">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" string="Assignment Title"/>
                            <h1><field name="name" placeholder="Title..."/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="class_id" options="{'no_create': True}"/>
                                <field name="teacher_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="due_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Requirements &amp; Materials">
                                <field name="description" placeholder="Write assignment instructions here..."/>
                                <separator string="Attachments"/>
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </page>
                            <page string="Submissions Overview">
                                <field name="submission_ids" readonly="1">
                                    <list>
                                        <field name="student_id"/>
                                        <field name="submission_date"/>
                                        <field name="score"/>
                                        <field name="feedback"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>