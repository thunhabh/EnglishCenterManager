<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_center_submission" model="ir.actions.act_window">
            <field name="name">Submissions</field>
            <field name="res_model">center.submission</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_center_submission_list" model="ir.ui.view">
            <field name="name">center.submission.list</field>
            <field name="model">center.submission</field>
            <field name="arch" type="xml">
                <list string="Student Submissions"
                      default_order="submission_date desc"
                      decoration-warning="score == -1"
                      decoration-success="score != -1">
                    <field name="assignment_id"/>
                    <field name="student_id"/>
                    <field name="submission_date"/>
                    <field name="score" widget="badge" invisible="score == -1"/>
                </list>
            </field>
        </record>

        <record id="view_center_submission_form" model="ir.ui.view">
            <field name="name">center.submission.form</field>
            <field name="model">center.submission</field>
            <field name="arch" type="xml">
                <form string="Student Submission">
                    <sheet>
                        <div class="oe_title">
                            <h1>Submission for <field name="student_id" readonly="1" force_save="1" class="text-primary"/></h1>
                        </div>
                        <group>
                            <group string="Homework Submission">
                                <field name="assignment_id" domain="[('class_id.student_ids.user_id', '=', uid)]"/>
                                <field name="file_name" invisible="1"/>
                                <field name="submission_file" filename="file_name"/>
                                <field name="submission_date" readonly="1"/>
                            </group>
                                <group string="Teacher's Evaluation" groups="english_center.group_center_teacher,base.group_erp_manager">
                                    <field name="score"/>
                                    <field name="feedback"/>
                                </group>

                                <group string="Teacher's Evaluation"
                                       groups="english_center.group_center_student"
                                        invisible="score == -1 and not feedback">
                                        <field name="score" readonly="1"/>
                                        <field name="feedback" readonly="1"/>
                                </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>