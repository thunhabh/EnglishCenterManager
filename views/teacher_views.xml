<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_center_teacher_list_clean" model="ir.ui.view">
            <field name="name">center.teacher.list.clean</field>
            <field name="model">hr.employee</field>
            <field name="priority">999</field>
            <field name="arch" type="xml">
                <list string="Teacher Profiles">
                    <field name="name"/>
                    <field name="work_email"/>
                    <field name="work_phone"/>
                </list>
            </field>
        </record>

        <record id="view_center_teacher_form_clean" model="ir.ui.view">
            <field name="name">center.teacher.form.clean</field>
            <field name="model">hr.employee</field>
            <field name="priority">999</field>
            <field name="arch" type="xml">
            <form string="Teacher Profile">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_teacher_schedule" type="object" class="oe_stat_button" icon="fa-calendar" groups="english_center.group_center_teacher,base.group_erp_manager">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Teaching Schedule</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" placeholder="Teacher's Name..."/></h1>

                        <field name="category_ids"
                            widget="many2many_tags"
                            options="{'color_field': 'color'}"
                            placeholder="Tags (e.g. IELTS Expert, Part-time...)"/>
                    </div>

                    <group>
                        <group string="Contact &amp; ID">
                            <field name="work_email"/>
                            <field name="work_phone"/>
                            <field name="identification_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

        <record id="view_assignment_list_teacher" model="ir.ui.view">
            <field name="name">assignment.list.teacher</field>
            <field name="model">center.assignment</field>
            <field name="arch" type="xml">
                <list decoration-success="state_for_teacher in ('all_submitted', 'finished')"
                      decoration-warning="state_for_teacher == 'partial'"
                      decoration-info="state_for_teacher == 'overdue'"
                      decoration-bf="state_for_teacher == 'finished'">
                        <field name="class_id"/>
                        <field name="state_for_teacher"/>
                </list>
            </field>
        </record>

        <record id="view_center_teacher_search_clean" model="ir.ui.view">
            <field name="name">center.teacher.search.clean</field>
            <field name="model">hr.employee</field>
            <field name="priority">999</field>
            <field name="arch" type="xml">
                <search string="Search Teachers">
                    <field name="name"/>
                    <field name="work_email"/>
                    <field name="work_phone"/>
                </search>
            </field>
        </record>

        <record id="action_my_profile_teacher" model="ir.actions.server">
            <field name="name">Open Teacher Profile</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">
                action = model.action_open_teacher_profile()
            </field>
        </record>

    </data>
</odoo>