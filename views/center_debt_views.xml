<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_center_debt_history_pivot" model="ir.ui.view">
        <field name="name">center.debt.history.pivot</field>
        <field name="model">center.debt.history</field>
        <field name="arch" type="xml">
            <pivot string="Revenue Analysis" sample="1">
                <field name="execution_date" type="row" interval="month"/>
                <field name="course_id" type="col"/>
                <field name="class_id" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_center_debt_history_graph" model="ir.ui.view">
        <field name="name">center.debt.history.graph</field>
        <field name="model">center.debt.history</field>
        <field name="arch" type="xml">
            <graph string="Dashboard" type="bar" sample="1">
                <field name="execution_date" interval="week"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_center_debt_history_list" model="ir.ui.view">
        <field name="name">center.debt.history.list</field>
        <field name="model">center.debt.history</field>
        <field name="arch" type="xml">
            <list string="Bills History" create="false" edit="false" delete="false">
                <field name="execution_date"/>
                <field name="student_id"/>
                <field name="course_id"/>
                <field name="class_id"/>
                <field name="session_id"/>
                <field name="amount" sum="Total"/>
            </list>
        </field>
    </record>

    <record id="action_center_revenue_report" model="ir.actions.act_window">
        <field name="name">Billing Reports</field>
        <field name="res_model">center.debt.history</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

</odoo>