<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_center_teacher" model="res.groups">
            <field name="name">Teacher</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <!--thừa kế quyền của base.group_user để đăng nhập vào backend-->
        </record>

        <record id="group_center_student" model="res.groups">
            <field name="name">Student</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
    <data noupdate="1">
        <record id="rule_student_schedule" model="ir.rule">
            <field name="name">Student: Own Class Schedule</field>
            <field name="model_id" ref="model_center_class_schedule"/>
            <field name="domain_force">[('class_id.student_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('english_center.group_center_student'))]"/>
        </record>

        <record id="rule_student_session" model="ir.rule">
            <field name="name">Student: Own Class Sessions</field>
            <field name="model_id" ref="model_class_session"/>
            <field name="domain_force">[('class_id.student_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('english_center.group_center_student'))]"/>
        </record>
    </data>
</odoo>